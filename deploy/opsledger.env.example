OPSLEDGER_ADDR=0.0.0.0:18090
OPSLEDGER_DATA=/var/lib/opsledger/opsledger.db
OPSLEDGER_DB_DRIVER=sqlite3
OPSLEDGER_DB_DSN=

# Required for production credential storage. Use a stable random value and back it up.
OPSLEDGER_CREDENTIAL_KEY=change-this-32-byte-secret-value

# Set true when served over HTTPS.
OPSLEDGER_COOKIE_SECURE=false

# Development only. Leave disabled for normal first deployment and use the setup wizard.
OPSLEDGER_DEV_SEED_USERS=0
OPSLEDGER_DEV_SEED_PASSWORD=
OPSLEDGER_SEED_EXAMPLE_TOOLS=0

# Optional SSH hardening.
OPSLEDGER_SSH_STRICT_HOST_KEY=false
OPSLEDGER_SSH_KNOWN_HOSTS=
OPSLEDGER_PVE_SSH_STRICT_HOST_KEY=false
OPSLEDGER_PVE_SSH_KNOWN_HOSTS=
